{
  "physics-type": "non-physics",

  "links": [{
        "name": "interceptor_body",

        "collision": {
            "enabled": true,
            "restitution": 0.1,
            "friction": 0.5
        },


        "visual": { 
            "geometry": {
                "type": "unreal_mesh",
                "name": "/Drone/Quadrotor1",
                "scale": "1.0 1.0 1.0"
            }
        }
    }],

    "sensors": [
        {
            "id": "InterceptionCamera",
            "type": "camera",
            "enabled": true,
            "parent-link": "interceptor_body",
            "origin": {
                "xyz": "0 0 -0.5",
                "rpy-deg": "0 0 0"
            },
            "capture-interval": 0.02,
            "capture-settings": [{
                "image-type": 0,
                "width": 640,
                "height": 640,
                "fov-degrees": 45,
                "capture-enabled": true,
                "streaming-enabled": false,
                "pixels-as-float": false,
                "compress": false
            }]

            
        }
        ]
}